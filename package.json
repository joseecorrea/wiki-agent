{
  "name": "wiki-agent",
  "version": "0.3.0",
  "description": "Persistent memory wiki for LLM agents — sub-agent orchestration, auto-learning, and BM25 search",
  "type": "module",
  "author": "Jose Correa <josecorreadev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joseecorrea/wiki-agent.git"
  },
  "bugs": {
    "url": "https://github.com/joseecorrea/wiki-agent/issues"
  },
  "homepage": "https://github.com/joseecorrea/wiki-agent#readme",
  "keywords": [
    "wiki",
    "agent",
    "mcp",
    "llm",
    "memory"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "wiki-agent": "dist/cli.js",
    "wiki-agent-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0"
  }
}
